<?xml version="1.0" ?>
<robot name="kumi">

  <material name="black">
    <color rgba="0.1 0.1 0.1 1.0"/>
  </material>
  <material name="gray">
    <color rgba="0.5 0.5 0.5 0.8"/>
  </material>
  <material name="green">
    <color rgba="0 1 0 0.8"/>
  </material>
  <material name="red">
    <color rgba="1 0 0 0.8"/>
  </material>

  <!-- ========== BODY ========== -->
  <link name="body">
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="meshes/body_v5.STL" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="gray"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="meshes/body_v5.STL" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <mass value="0.15"/>
      <inertia ixx="0.000226" ixy="0.0" ixz="0.0" iyy="0.000755" iyz="0.0" izz="0.000971"/>
    </inertial>
  </link>

  <!-- ========== FRONT LEG ========== -->
  <joint name="front_sh" type="revolute">
    <origin rpy="0 0 0" xyz="-0.09 -0.006 0"/>
    <parent link="body"/>
    <child link="front_leg"/>
    <axis xyz="0 -1 0"/>
    <limit effort="1000" lower="-6.283185307179586" upper="6.283185307179586" velocity="5"/>
    <dynamics damping="0.5" friction="0.2"/>
  </joint>

  <link name="front_leg">
    <visual>
      <origin rpy="0 -1.5707963267948966 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="meshes/leg_v2.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="gray"/>
    </visual>
    <collision>
      <origin rpy="0 -1.5707963267948966 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="meshes/leg_v2.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
    <inertial>
      <origin rpy="0 -1.5707963267948966 0" xyz="0 0 0"/>
      <mass value="0.212"/>
      <inertia ixx="0.001148663" ixy="0.0" ixz="0.0" iyy="0.001120663" iyz="-0.000045" izz="0.000046"/>
    </inertial>
  </link>

  <!-- ========== FRONT ANKLE ========== -->
  <joint name="front_ank_y" type="revolute">
    <origin rpy="0 0 0" xyz="0 0 -0.11"/>
    <parent link="front_leg"/>
    <child link="front_foot_dummy"/>
    <axis xyz="0 -1 0"/>
    <limit effort="1000" lower="-6.283185307179586" upper="6.283185307179586" velocity="5"/>
    <dynamics damping="0.1" friction="0.2"/>
  </joint>

  <link name="front_foot_dummy">
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <mass value="0.001"/>
      <inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5"/>
    </inertial>
  </link>

  <joint name="front_ank_z" type="revolute">
    <origin rpy="0 0 0" xyz="0 0 0"/>
    <parent link="front_foot_dummy"/>
    <child link="front_foot"/>
    <axis xyz="0 0 1"/>
    <limit effort="1000" lower="-0.3141592653589793" upper="0.3141592653589793" velocity="5"/>
    <dynamics damping="0.1" friction="0.2"/>
  </joint>

  <link name="front_foot">
    <visual>
      <origin rpy="1.5707963267948966 0 -1.5707963267948966" xyz="0 -0.007 0"/>
      <geometry>
        <mesh filename="meshes/piedino_v3.STL" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="green"/>
    </visual>
    <collision>
      <origin rpy="1.5707963267948966 0 -1.5707963267948966" xyz="0 0 0"/>
      <geometry>
        <mesh filename="meshes/piedino_v3.STL" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
    <inertial>
      <origin rpy="1.5707963267948966 0 -1.5707963267948966" xyz="0 0 0"/>
      <mass value="0.15"/>
      <inertia ixx="0.000091" ixy="0.0" ixz="0.0" iyy="0.000165" iyz="0.0" izz="0.000091"/>
    </inertial>
  </link>

  <!-- ========== REAR LEG ========== -->
  <joint name="rear_sh" type="revolute">
    <origin rpy="0 0 0" xyz="0.09 0.006 0"/>
    <parent link="body"/>
    <child link="rear_leg"/>
    <axis xyz="0 1 0"/>
    <limit effort="1000" lower="-6.283185307179586" upper="6.283185307179586" velocity="5"/>
    <dynamics damping="0.5" friction="0.2"/>
  </joint>

  <link name="rear_leg">
    <visual>
      <origin rpy="0 -1.5707963267948966 3.141592653589793" xyz="0 0 0"/>
      <geometry>
        <mesh filename="meshes/leg_v2.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="gray"/>
    </visual>
    <collision>
      <origin rpy="0 -1.5707963267948966 3.141592653589793" xyz="0 0 0"/>
      <geometry>
        <mesh filename="meshes/leg_v2.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
    <inertial>
      <origin rpy="0 -1.5707963267948966 3.141592653589793" xyz="0 0 0"/>
      <mass value="0.212"/>
      <inertia ixx="0.001148663" ixy="0.0" ixz="0.0" iyy="0.001120663" iyz="-0.000045" izz="0.000046"/>
    </inertial>
  </link>

  <!-- ========== REAR ANKLE ========== -->
  <joint name="rear_ank_y" type="revolute">
    <origin rpy="0 0 0" xyz="0 0 -0.11"/>
    <parent link="rear_leg"/>
    <child link="rear_foot_dummy"/>
    <axis xyz="0 1 0"/>
    <limit effort="1000" lower="-6.283185307179586" upper="6.283185307179586" velocity="5"/>
    <dynamics damping="0.1" friction="0.2"/>
  </joint>

  <link name="rear_foot_dummy">
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <mass value="0.001"/>
      <inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5"/>
    </inertial>
  </link>

  <joint name="rear_ank_z" type="revolute">
    <origin rpy="0 0 0" xyz="0 0 0"/>
    <parent link="rear_foot_dummy"/>
    <child link="rear_foot"/>
    <axis xyz="0 0 1"/>
    <limit effort="1000" lower="-0.3141592653589793" upper="0.3141592653589793" velocity="5"/>
    <dynamics damping="0.1" friction="0.2"/>
  </joint>

  <link name="rear_foot">
    <visual>
      <origin rpy="1.5707963267948966 0 1.5707963267948966" xyz="0 0.007 0"/>
      <geometry>
        <mesh filename="meshes/piedino_v3.STL" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="red"/>
    </visual>
    <collision>
      <origin rpy="1.5707963267948966 0 1.5707963267948966" xyz="0 0 0"/>
      <geometry>
        <mesh filename="meshes/piedino_v3.STL" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
    <inertial>
      <origin rpy="1.5707963267948966 0 1.5707963267948966" xyz="0 0 0"/>
      <mass value="0.15"/>
      <inertia ixx="0.000091" ixy="0.0" ixz="0.0" iyy="0.000165" iyz="0.0" izz="0.000091"/>
    </inertial>
  </link>

  <!-- ========== REALSENSE (struttura, no sensori) ========== -->
  <joint name="realsense_joint" type="fixed">
    <origin rpy="0 0 0" xyz="0 0 0"/>
    <parent link="front_leg"/>
    <child link="realsense"/>
  </joint>

  <link name="realsense">
    <visual>
      <origin rpy="1.5707963267948966 0 -1.5707963267948966" xyz="-0.025 0 -0.057"/>
      <geometry>
        <box size="0.03 0.03 0.06"/>
      </geometry>
      <material name="green"/>
    </visual>
    <collision>
      <origin rpy="1.5707963267948966 0 -1.5707963267948966" xyz="-0.025 0 -0.057"/>
      <geometry>
        <box size="0.03 0.03 0.06"/>
      </geometry>
    </collision>
    <inertial>
      <origin rpy="1.5707963267948966 0 -1.5707963267948966" xyz="-0.025 0 -0.057"/>
      <mass value="0.005"/>
      <inertia ixx="0.000091" ixy="0.0" ixz="0.0" iyy="0.000165" iyz="0.0" izz="0.000091"/>
    </inertial>
  </link>

</robot>
