<?xml version="1.0" ?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro"  name="kumi">

    <link name="body">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <box size="${lenght} ${thikness} ${thikness}" />
            </geometry>
            <material name="green">
                <color rgba="1 0 0 1"/>
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <box size="${lenght-toll} ${thikness-toll} ${thikness-toll}" />
            </geometry>
        </collision>
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="0.4" />
            <inertia ixx="0.001875" ixy="0.0" ixz="0.0" iyy="0.011354" iyz="0.0" izz="0.011354" />
        </inertial>
    </link>
   
   <joint name="front_sh" type="revolute">
        <origin xyz="${lenght} 0 0" rpy="0 0 0"/>
        <parent link="body"/>
        <child link="front_leg"/>
        <axis xyz="0 1 0"/>
        <limit lower="-0.85" upper="${pi - 0.85}" velocity="5" effort="6"/> 
        <dynamics damping="0.5" friction="${joint_friction}"/>
    </joint>

    <link name="front_leg">
        <visual>
            <origin xyz="0 0 ${-leg_len/2}" rpy="0 0 0"/>
            <geometry>
                <box size="${thikness} ${thikness} ${leg_len/2}" />
            </geometry>
            <material name="orange">
                <color rgba="0.7 0.7 0 1"/>
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 ${-leg_len/2}" rpy="0 0 0"/>
            <geometry>
                <box size="${thikness-toll} ${thikness-toll} ${leg_len/2-toll}" />
            </geometry>
        </collision>
        <inertial>
            <origin xyz="0 0 ${-leg_len/2}" rpy="0 0 0"/>
            <mass value="0.2" />
            <inertia ixx="0.001562" ixy="0.0" ixz="0.0" iyy="0.001562" iyz="0.0" izz="0.001125" />
        </inertial>
    </link>

    <joint name="front_knee" type="revolute">
        <origin xyz="0 0 ${-leg_len}" rpy="0 0 0"/>
        <parent link="front_leg"/>
        <child link="front_leg_d"/>
        <axis xyz="0 0 1"/>
        <limit lower="0.0" upper="0.0" velocity="5" effort="2"/> 
        <dynamics damping="10.0" friction="10.0"/>
    </joint>

    <link name="front_leg_d">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <box size="${thikness} ${thikness} ${leg_len/2}" />
            </geometry>
            <material name="orange">
                <color rgba="0.7 0.7 0 1"/>
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <box size="${thikness-toll} ${thikness-toll} ${leg_len/2-toll}" />
            </geometry>
        </collision>
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="0.2" />
            <inertia ixx="0.001562" ixy="0.0" ixz="0.0" iyy="0.001562" iyz="0.0" izz="0.001125" />
        </inertial>
    </link>

    <joint name="front_ank" type="revolute">
        <origin xyz="0 0 ${-leg_len/4 - thikness/4}" rpy="0 0 0"/>
        <parent link="front_leg_d"/>
        <child link="front_foot"/>
        <axis xyz="0 1 0"/>
        <limit lower="-0.85" upper="0.85" velocity="5" effort="6"/> 
        <dynamics damping="0.1" friction="${joint_friction}"/>
    </joint>

    <link name="front_foot">
        <visual>
            <origin xyz="0 0 ${-leg_len/4 - thikness/4}" rpy="0 0 0"/>
            <geometry>
                <box size="${foot_len} ${foot_len} ${thikness/2}" />
            </geometry>
            <material name="white">
                <color rgba="0 0.5 0.8 1"/>
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 ${-leg_len/4 - thikness/4}" rpy="0 0 0"/>
            <geometry>
                <box size="${foot_len-toll} ${foot_len-toll} ${thikness/2-toll}" />
            </geometry>
        </collision>
        <inertial>
            <origin xyz="0 0 ${-leg_len/4 - thikness/4}" rpy="0 0 0"/>
            <mass value="0.15" />
            <inertia ixx="0.001135" ixy="0.0" ixz="0.0" iyy="0.001135" iyz="0.0" izz="0.002083" />
        </inertial>
    </link>

    <joint name="rear_sh" type="revolute">
        <origin xyz="${-lenght} 0 0" rpy="0 0 0"/>
        <parent link="body"/>
        <child link="rear_leg"/>
        <axis xyz="0 1 0"/>
        <limit lower="${-pi + 0.3}" upper="0.3" velocity="5" effort="6"/> 
        <dynamics damping="0.1" friction="${joint_friction}"/>
    </joint>


    <link name="rear_leg">
        <visual>
            <origin xyz="0 0 ${-leg_len/2}" rpy="0 0 0"/>
            <geometry>
                <box size="${thikness} ${thikness} ${leg_len/2}" />
            </geometry>
            <material name="orange">
                <color rgba="0.7 0.7 0 1"/>
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 ${-leg_len/2}" rpy="0 0 0"/>
            <geometry>
                <box size="${thikness-toll} ${thikness-toll} ${leg_len/2-toll}" />
            </geometry>
        </collision>
        <inertial>
            <origin xyz="0 0 ${-leg_len/2}" rpy="0 0 0"/>
            <mass value="0.2" />
            <inertia ixx="0.001562" ixy="0.0" ixz="0.0" iyy="0.001562" iyz="0.0" izz="0.001125" />
        </inertial>
    </link>

    <joint name="rear_knee" type="revolute">
        <origin xyz="0 0 ${-leg_len}" rpy="0 0 0"/>
        <parent link="rear_leg"/>
        <child link="rear_leg_d"/>
        <axis xyz="0 0 1"/>
        <limit lower="0.0" upper="0.0" velocity="5" effort="2"/> 
        <dynamics damping="10.0" friction="10.0"/>
    </joint>


    <link name="rear_leg_d">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <box size="${thikness} ${thikness} ${leg_len/2}" />
            </geometry>
            <material name="orange">
                <color rgba="0.7 0.7 0 1"/>
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <box size="${thikness-toll} ${thikness-toll} ${leg_len/2-toll}" />
            </geometry>
        </collision>
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="0.2" />
            <inertia ixx="0.001562" ixy="0.0" ixz="0.0" iyy="0.001562" iyz="0.0" izz="0.001125" />
        </inertial>
    </link>

    <joint name="rear_ank" type="revolute">
        <origin xyz="0 0 ${-leg_len/4 - thikness/4}" rpy="0 0 0"/>
        <parent link="rear_leg_d"/>
        <child link="rear_foot"/>
        <axis xyz="0 1 0"/>
        <limit lower="-0.85" upper="0.85" velocity="5" effort="6"/> 
        <dynamics damping="0.1" friction="${joint_friction}"/>
    </joint>


    <link name="rear_foot">
        <visual>
            <origin xyz="0 0 ${-leg_len/4 - thikness/4}" rpy="0 0 0"/>
            <geometry>
                <box size="${foot_len} ${foot_len} ${thikness/2}" />
            </geometry>
            <material name="white">
                <color rgba="0 0.5 0.8 1"/>
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 ${-leg_len/4 - thikness/4}" rpy="0 0 0"/>
            <geometry>
                <box size="${foot_len-toll} ${foot_len-toll} ${thikness/2-toll}" />
            </geometry>
        </collision>
        <inertial>
            <origin xyz="0 0 ${-leg_len/4 - thikness/4}" rpy="0 0 0"/>
            <mass value="0.15" />
            <inertia ixx="0.001135" ixy="0.0" ixz="0.0" iyy="0.001135" iyz="0.0" izz="0.002083" />
        </inertial>
    </link>


</robot>