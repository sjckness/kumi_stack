<?xml version="1.0" ?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="kumi">

    <link name="body">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <mesh filename="${body_mesh}" scale="${mesh_scale}"/>
            </geometry>
            <material name="gray"/>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <mesh filename="${body_mesh}" scale="${mesh_scale}"/>
            </geometry>
        </collision>
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="0.15"/>
            <inertia ixx="0.000226" ixy="0.0" ixz="0.0" iyy="0.000755" iyz="0.0" izz="0.000971"/>
        </inertial>
    </link>

    <joint name="front_sh" type="revolute">
        <origin xyz="${-lenght/2} -0.006 0" rpy="0 0 0"/>
        <parent link="body"/>
        <child link="front_leg"/>
        <axis xyz="0 -1 0"/>
        <limit lower="${-2*pi}" upper="${2*pi}" velocity="5" effort="1000"/>
        <dynamics damping="0.5" friction="${joint_friction}"/>
    </joint>

    <link name="front_leg">
        <visual>
            <origin xyz="0 0 0" rpy="0 ${-pi/2} 0"/>
            <geometry>
                <mesh filename="${leg_mesh}" scale="${mesh_scale}"/>
            </geometry>
            <material name="gray"/>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 ${-pi/2} 0"/>
            <geometry>
                <mesh filename="${leg_mesh}" scale="${mesh_scale}"/>
            </geometry>
        </collision>
        <inertial>
            <origin xyz="0 0 0" rpy="0 ${-pi/2} 0"/>
            <mass value="0.3"/>
            <inertia ixx="0.000023773" ixy="0.0" ixz="0.0" iyy="0.000513246" iyz="0.0" izz="0.000524232"/>
        </inertial>
    </link>

    <joint name="realsense_joint" type="fixed">
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <parent link="front_leg"/>
        <child link="realsense"/>
    </joint>

    <link name="realsense">
        <visual>
            <origin xyz="-0.025 0 -0.057" rpy="${pi/2} 0 0"/>
            <geometry>
                <box size="0.03 0.03 0.06"/>
            </geometry>
            <material name="green"/>
        </visual>
        <collision>
            <origin xyz="-0.025 0 -0.057" rpy="${pi/2} 0 0"/>
            <geometry>
                <box size="0.03 0.03 0.06"/>
            </geometry>
        </collision>
        <inertial>
            <origin xyz="-0.025 0 -0.057" rpy="${pi/2} 0 0"/>
            <mass value="0.005"/>
            <inertia ixx="0.000091" ixy="0.0" ixz="0.0" iyy="0.000165" iyz="0.0" izz="0.000091"/>
        </inertial>
    </link>

    <joint name="front_ank_y" type="revolute">
        <origin xyz="0 0 ${-leg_len}" rpy="0 0 0"/>
        <parent link="front_leg"/>
        <child link="front_foot_dummy"/>
        <axis xyz="0 -1 0"/>
        <limit lower="${-2*pi}" upper="${2*pi}" velocity="5" effort="1000"/>
        <dynamics damping="0.1" friction="${joint_friction}"/>
    </joint>

    <link name="front_foot_dummy">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="0.001"/>
            <inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5"/>
        </inertial>
    </link>

    <joint name="front_ank_z" type="revolute">
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <parent link="front_foot_dummy"/>
        <child link="front_foot"/>
        <axis xyz="0 0 1"/>
        <limit lower="${-0.1*pi}" upper="${0.1*pi}" velocity="5" effort="1000"/>
        <dynamics damping="0.1" friction="${joint_friction}"/>
    </joint>

    <link name="front_foot">
        <visual>
            <origin xyz="0 -0.007 0" rpy="${pi/2} 0 ${-pi/2}"/>
            <geometry>
                <mesh filename="${foot_mesh}" scale="${mesh_scale}"/>
            </geometry>
            <material name="green"/>
        </visual>
        <collision name="frontFootCollision">
            <origin xyz="0 0 0" rpy="${pi/2} 0 ${-pi/2}"/>
            <geometry>
                <mesh filename="${foot_mesh}" scale="${mesh_scale}"/>
            </geometry>
        </collision>
        <inertial>
            <origin xyz="0 0 0" rpy="${pi/2} 0 ${-pi/2}"/>
            <mass value="0.15"/>
            <inertia ixx="0.000091" ixy="0.0" ixz="0.0" iyy="0.000165" iyz="0.0" izz="0.000091"/>
        </inertial>
    </link>

    <gazebo reference="front_foot">
        <mu1>${foot_contact_friction}</mu1>
        <mu2>${foot_contact_friction}</mu2>
    </gazebo>

    <joint name="rear_sh" type="revolute">
        <origin xyz="${lenght/2} 0.006 0" rpy="0 0 0"/>
        <parent link="body"/>
        <child link="rear_leg"/>
        <axis xyz="0 1 0"/>
        <limit lower="${-2*pi}" upper="${2*pi}" velocity="5" effort="1000"/>
        <dynamics damping="0.5" friction="${joint_friction}"/>
    </joint>

    <link name="rear_leg">
        <visual>
            <origin xyz="0 0 0" rpy="0 ${-pi/2} ${pi}"/>
            <geometry>
                <mesh filename="${leg_mesh}" scale="${mesh_scale}"/>
            </geometry>
            <material name="gray"/>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 ${-pi/2} ${pi}"/>
            <geometry>
                <mesh filename="${leg_mesh}" scale="${mesh_scale}"/>
            </geometry>
        </collision>
        <inertial>
            <origin xyz="0 0 0" rpy="0 ${-pi/2} ${pi}"/>
            <mass value="0.3"/>
            <inertia ixx="0.000023773" ixy="0.0" ixz="0.0" iyy="0.000513246" iyz="0.0" izz="0.000524232"/>
        </inertial>
    </link>

    <joint name="rear_ank_y" type="revolute">
        <origin xyz="0 0 ${-leg_len}" rpy="0 0 0"/>
        <parent link="rear_leg"/>
        <child link="rear_foot_dummy"/>
        <axis xyz="0 1 0"/>
        <limit lower="${-2*pi}" upper="${2*pi}" velocity="5" effort="1000"/>
        <dynamics damping="0.1" friction="${joint_friction}"/>
    </joint>

    <link name="rear_foot_dummy">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="0.001"/>
            <inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5"/>
        </inertial>
    </link>

    <joint name="rear_ank_z" type="revolute">
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <parent link="rear_foot_dummy"/>
        <child link="rear_foot"/>
        <axis xyz="0 0 1"/>
        <limit lower="${-0.1*pi}" upper="${0.1*pi}" velocity="5" effort="1000"/>
        <dynamics damping="0.1" friction="${joint_friction}"/>
    </joint>

    <link name="rear_foot">
        <visual>
            <origin xyz="0 0.007 0" rpy="${pi/2} 0 ${pi/2}"/>
            <geometry>
                <mesh filename="${foot_mesh}" scale="${mesh_scale}"/>
            </geometry>
            <material name="red"/>
        </visual>
        <collision name="rearFootCollision">
            <origin xyz="0 0 0" rpy="${pi/2} 0 ${pi/2}"/>
            <geometry>
                <mesh filename="${foot_mesh}" scale="${mesh_scale}"/>
            </geometry>
        </collision>
        <inertial>
            <origin xyz="0 0 0" rpy="${pi/2} 0 ${pi/2}"/>
            <mass value="0.15"/>
            <inertia ixx="0.000091" ixy="0.0" ixz="0.0" iyy="0.000165" iyz="0.0" izz="0.000091"/>
        </inertial>
    </link>

    <gazebo reference="rear_foot">
        <mu1>${foot_contact_friction}</mu1>
        <mu2>${foot_contact_friction}</mu2>
    </gazebo>

</robot>
